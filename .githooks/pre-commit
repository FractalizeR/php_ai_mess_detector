#!/bin/bash

# Pre-commit hook for AI Mess Detector
# Runs code style and static analysis checks on changed files

set -e

echo "🔍 Running pre-commit checks..."

# Get list of changed PHP files (exclude invalid syntax fixtures)
STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' | grep -v 'Fixtures/Ast/invalid_syntax.php' || true)

if [ -z "$STAGED_PHP_FILES" ]; then
    echo "✅ No PHP files to check"
    exit 0
fi

echo "📝 Checking files:"
echo "$STAGED_PHP_FILES"
echo ""

# PHP-CS-Fixer: style check (check only, no fix)
echo "🎨 Running PHP-CS-Fixer (dry-run)..."
if ! vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff $STAGED_PHP_FILES 2>/dev/null; then
    echo ""
    echo "❌ Code style issues found!"
    echo "Run 'composer cs-fix' to fix them automatically"
    exit 1
fi
echo "✅ Code style OK"

# PHPStan: static analysis
echo ""
echo "🔬 Running PHPStan..."
if ! vendor/bin/phpstan analyse $STAGED_PHP_FILES --no-progress --memory-limit=512M 2>/dev/null; then
    echo ""
    echo "❌ PHPStan found issues!"
    exit 1
fi
echo "✅ PHPStan OK"

echo ""
echo "✅ All pre-commit checks passed!"
